# Network Agent Environment Variables
# Copy this file to .env and fill in your values

# Encryption key for credential storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NETAGENT_ENCRYPTION_KEY=

# Web dashboard secret key (any random string)
NETAGENT_SECRET_KEY=change-me-to-a-random-string

# Anthropic API key for AI chat agent
ANTHROPIC_API_KEY=

# Optional: Web dashboard admin credentials
# NETAGENT_ADMIN_USER=admin
# NETAGENT_ADMIN_PASSWORD=admin

# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=

# Optional: SMTP password for email alerts
SMTP_PASSWORD=
